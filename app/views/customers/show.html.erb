<div class="space-y-6">
  <div class="rounded-lg border bg-white p-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-3xl font-bold"><%= @customer.name %></h1>
        <p class="mt-2 text-stone-600"><%= @customer.phone.presence || "Sem telefone" %></p>
        <p class="mt-2 text-stone-600"><%= @customer.address.presence || "Sem endereco" %></p>
      </div>
      <%= link_to "Editar", edit_customer_path(@customer), class: "rounded-md border px-4 py-2" %>
    </div>
  </div>
  <section class="rounded-lg border bg-white">
    <div class="border-b px-4 py-3"><h2 class="font-semibold">Historico de pedidos</h2></div>
    <% @orders.each do |order| %>
      <div class="flex items-center justify-between border-b p-4 last:border-0">
        <div>
          <%= link_to "Pedido ##{order.id}", order, class: "font-medium text-red-800" %>
          <p class="text-sm text-stone-500"><%= order_status_label(order.status) %> - <%= order_type_label(order.order_type) %></p>
        </div>
        <p class="font-semibold"><%= brl(order.total) %></p>
      </div>
    <% end %>
  </section>
</div>
