<div class="mx-auto max-w-md rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-red-800">Entrar</h1>
  <p class="mt-1 text-sm text-stone-600">Acesse o painel da espetaria.</p>

  <%= form_with url: login_path, class: "mt-6 space-y-4" do |form| %>
    <div>
      <%= form.label :email, "Email", class: "text-sm font-medium" %>
      <%= form.email_field :email, class: "mt-1 w-full rounded-md border-stone-300" %>
    </div>
    <div>
      <%= form.label :password, "Senha", class: "text-sm font-medium" %>
      <%= form.password_field :password, class: "mt-1 w-full rounded-md border-stone-300" %>
    </div>
    <%= form.submit "Entrar", class: "w-full rounded-md bg-red-800 px-4 py-2 font-medium text-white hover:bg-red-900" %>
  <% end %>
</div>
