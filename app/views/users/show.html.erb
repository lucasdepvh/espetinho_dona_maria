<div class="rounded-lg border bg-white p-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-3xl font-bold"><%= @user.name %></h1>
      <p class="mt-2 text-stone-600"><%= @user.email %></p>
      <p class="mt-2 text-sm"><%= @user.admin? ? "Admin" : "Atendente" %> - <%= @user.active? ? "Ativo" : "Inativo" %></p>
    </div>
    <%= link_to "Editar", edit_user_path(@user), class: "rounded-md border px-4 py-2" %>
  </div>
</div>
