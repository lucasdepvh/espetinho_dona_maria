<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold">Usuarios</h1>
    <%= link_to "Novo usuario", new_user_path, class: "rounded-md bg-red-800 px-4 py-2 text-white" %>
  </div>
  <div class="rounded-lg border bg-white">
    <% @users.each do |user| %>
      <div class="flex items-center justify-between border-b p-4 last:border-0">
        <div>
          <%= link_to user.name, user, class: "font-semibold text-red-800" %>
          <p class="text-sm text-stone-500"><%= user.email %> - <%= user.admin? ? "Admin" : "Atendente" %> - <%= user.active? ? "Ativo" : "Inativo" %></p>
        </div>
        <%= link_to "Editar", edit_user_path(user), class: "text-sm text-stone-600 hover:text-red-800" %>
      </div>
    <% end %>
  </div>
</div>
