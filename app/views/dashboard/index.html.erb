<% content_for :title, "#{@setting.establishment_name} - Dashboard" %>
<% content_for :body_class, "bg-[#121414] text-stone-100 antialiased" %>
<% content_for :main_class, "pb-28" %>
<% content_for :hide_app_header, true %>

<header class="fixed inset-x-0 top-0 z-50 border-b border-stone-800 bg-[#121414]/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <div class="flex items-center gap-4">
      <button type="button" class="flex h-11 w-11 items-center justify-center rounded-full text-orange-300 transition hover:bg-stone-800">
        <span aria-hidden="true" class="text-xl">☰</span>
      </button>
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-stone-500">Dashboard</p>
        <h1 class="text-base font-semibold text-orange-300 sm:text-lg"><%= @setting.establishment_name.upcase %></h1>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to orders_path, class: "relative flex h-11 w-11 items-center justify-center rounded-full text-orange-300 transition hover:bg-stone-800" do %>
        <span aria-hidden="true" class="text-lg">🛒</span>
        <span id="cart-count" class="absolute right-1 top-1 flex h-5 min-w-5 items-center justify-center rounded-full bg-orange-500 px-1 text-[11px] font-bold text-stone-950"><%= @active_orders_count %></span>
      <% end %>
    </div>
  </div>
</header>

<section class="relative mx-auto max-w-6xl px-4 pt-20 sm:px-6">
  <div class="absolute inset-x-0 top-0 -z-10 h-64 bg-[radial-gradient(circle_at_top,_rgba(249,115,22,0.18),_transparent_55%)]"></div>

  <div class="space-y-6 py-8">
    <div class="space-y-2">
      <p class="text-sm font-medium text-amber-200">Bem-vindo, <%= current_user.name %></p>
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl space-y-2">
          <h2 class="text-4xl font-bold leading-tight text-stone-100 sm:text-5xl">Olá, o que vamos <span class="text-orange-400">grelhar</span> hoje?</h2>
          <p class="text-sm text-stone-400 sm:text-base"><%= @setting.address.presence || "Monte o pedido, acompanhe a cozinha e feche o atendimento sem sair desta tela." %></p>
        </div>

        <div class="grid grid-cols-2 gap-3 sm:min-w-[320px]">
          <div class="rounded-2xl border border-stone-800 bg-stone-900/80 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-stone-500">Pedidos hoje</p>
            <p class="mt-2 text-2xl font-bold text-stone-100"><%= @orders_today.count %></p>
          </div>
          <div class="rounded-2xl border border-stone-800 bg-stone-900/80 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-stone-500">Faturamento</p>
            <p class="mt-2 text-2xl font-bold text-stone-100"><%= brl(@revenue_today) %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="relative">
      <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-stone-500">⌕</span>
      <input type="text" placeholder="Buscar espetos, bebidas..." class="h-14 w-full rounded-2xl border border-stone-800 bg-stone-900/80 pl-12 pr-4 text-stone-100 placeholder:text-stone-500 focus:border-orange-400 focus:outline-none focus:ring-2 focus:ring-orange-500/30">
    </div>
  </div>
</section>

<section class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold text-stone-100">Ofertas de Brasa</h3>
      <p class="text-sm text-stone-400">Produtos em destaque para acelerar o atendimento.</p>
    </div>
    <%= link_to "Ver todos", current_user.admin? ? products_path : new_order_path, class: "text-sm font-semibold text-orange-300 hover:text-orange-200" %>
  </div>

  <div class="flex snap-x gap-4 overflow-x-auto pb-2">
    <% @featured_products.each_with_index do |product, index| %>
      <article class="relative h-52 min-w-[300px] snap-start overflow-hidden rounded-2xl border border-stone-800 bg-stone-900">
        <img src="<%= index.zero? ? 'https://lh3.googleusercontent.com/aida-public/AB6AXuBex-on0puB4vYvfdyZGQ7x3Uq0Ps67pKOx9QhBsOOhlQPb-8MMBIMskq4qk5ADCyF6p4vNEJcV88i-t8v6IVFlTUxKKG7e5BGD4295lH50VygGYmFR8opImnwK5YS2XDVaAlZ9Gq58mkQOitF8kIMD_ovpRG8DmRsbciwD331ZHgBYwZou5TsS--O2JaUDN3fOtnFxYaymIzOojtOE30huaBadbodGDKVEXyJ6rRUZPJl5gB5vJJsd9LhIHiEAt0xGv-yW3jZ7YWjt' : 'https://lh3.googleusercontent.com/aida-public/AB6AXuCHdtV6TqIjslCjlGF5KskzHypVFSKOoRlW5B0zm2w2PHLAkHbX5dobe6QAJ5Uh3LL7RbgSkMvxbJ7DdkpgfIN0ddbqpWu-mkiJnZMmAAmtBFPHbQsDlKfYqK3h23EjHInCtvuR8D6jWxRyPWjCYKwZftk6YbPMymqYh5wE2y7WDYTXW6VQsXoOXEQ-Pl7GgbA13ndm7Z7Y94D_OQtx8DjKwESe51P13BtYssvZteO1z-II9_zhtWGHB6LCwG5epx3WP3K_5gG_03lP' %>" alt="<%= product.name %>" class="absolute inset-0 h-full w-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-5">
          <span class="mb-3 inline-flex rounded-md bg-amber-300 px-2 py-1 text-[11px] font-bold tracking-wide text-stone-950"><%= dashboard_promo_label(product) %></span>
          <h4 class="text-xl font-bold text-white"><%= product.name %></h4>
          <p class="mt-1 text-sm text-stone-200"><%= dashboard_product_description(product) %></p>
          <p class="mt-3 text-lg font-bold text-orange-300"><%= brl(product.price) %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <h3 class="mb-5 text-2xl font-semibold text-stone-100">Categorias</h3>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <% @categories.each do |category| %>
      <article class="rounded-2xl border border-stone-800 bg-stone-900/70 p-4 transition hover:border-orange-400">
        <div class="flex aspect-square items-center justify-center rounded-2xl bg-stone-800 text-4xl">
          <span aria-hidden="true"><%= dashboard_category_icon(category.name) %></span>
        </div>
        <div class="mt-3">
          <h4 class="font-semibold text-stone-100"><%= category.name %></h4>
          <p class="mt-1 text-sm text-stone-400"><%= dashboard_category_label(category) %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold text-stone-100">Os Favoritos</h3>
      <p class="text-sm text-stone-400">Itens com giro alto para o balcão.</p>
    </div>
    <%= link_to "Ver todos", new_order_path, class: "text-sm font-semibold text-orange-300 hover:text-orange-200" %>
  </div>

  <div class="grid gap-4 lg:grid-cols-2">
    <% @popular_products.each_with_index do |product, index| %>
      <article class="flex gap-4 rounded-2xl border border-stone-800 bg-stone-900/80 p-3 transition hover:border-orange-400">
        <div class="h-24 w-24 flex-none overflow-hidden rounded-xl">
          <img src="<%= index.even? ? 'https://lh3.googleusercontent.com/aida-public/AB6AXuBOBQSrZ_R1r1xkSXBlK4hJM0b1b0r3Bxxlx7891BVxymm54SkeNUCUDNJ7U3EnNHq7Z4S7u5-YFyaVbmwMjuWvQPXmWzhg9S2L9iKZl2nd365JAkSJyVV5rY_tRqRtdYB_D0FVuSmZErAdmNRvBWH5KhKddbMEwerz3FepMjKehpSNbtIGr-tPh6-KjG2B3OcEou7iNM0j2eyIuCL7O8SoeAOKhrtbG0Yo19Rpfm3js0ChX8tFRhVful9L1UxKUH8aDs0LV3g6tZuZ' : 'https://lh3.googleusercontent.com/aida-public/AB6AXuDCO_sW1LdWdL0xQ2J_9l_lvSNJM1hiE7RWWATVTTbsusnMxeLs6gYg7m4l5noFe7eMGko5Vl65mrSRzESQAzben3UAZIfQTcd_4hQeIggjPWLOv1PzOO3MYaAvihM88Gyi9L34i-kekLDRUeZXdx_7-fKq-TZmzQv-KdFQN2tIjtb42thXs-AcckzZdxsEfK0BZkM4jpAAjNUiO06J1gobU8N36ag2-aofO9fSJQkbE1Vr5__urNQ1wy4kMjNvCMtw-lhwCK7ibVTy' %>" alt="<%= product.name %>" class="h-full w-full object-cover">
        </div>
        <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
          <div class="min-w-0">
            <h4 class="truncate text-base font-semibold text-stone-100"><%= product.name %></h4>
            <p class="mt-1 line-clamp-2 text-sm text-stone-400"><%= dashboard_product_description(product) %></p>
            <p class="mt-3 text-lg font-bold text-orange-300"><%= brl(product.price) %></p>
          </div>
          <button type="button" data-add-item class="flex h-11 w-11 flex-none items-center justify-center rounded-full bg-orange-500 text-2xl font-semibold text-stone-950 transition hover:bg-orange-400">
            <span data-add-icon>+</span>
          </button>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="mx-auto mb-8 max-w-6xl px-4 sm:px-6">
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold text-stone-100">Pedidos em andamento</h3>
      <p class="text-sm text-stone-400">Acompanhe o que precisa de atencao imediata.</p>
    </div>
    <%= link_to "Abrir pedidos", orders_path, class: "text-sm font-semibold text-orange-300 hover:text-orange-200" %>
  </div>

  <div class="grid gap-3">
    <% if @latest_orders.any? %>
      <% @latest_orders.each do |order| %>
        <%= link_to order_path(order), class: "flex flex-col gap-3 rounded-2xl border border-stone-800 bg-stone-900/70 p-4 transition hover:border-orange-400 sm:flex-row sm:items-center sm:justify-between" do %>
          <div>
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-stone-800 px-3 py-1 text-xs font-semibold text-stone-300">Pedido #<%= order.id %></span>
              <span class="rounded-full px-3 py-1 text-xs font-semibold <%= dashboard_status_badge_class(order.status) %>"><%= order_status_label(order.status) %></span>
            </div>
            <p class="mt-3 text-base font-semibold text-stone-100"><%= order.customer.name %></p>
            <p class="text-sm text-stone-400"><%= order_type_label(order.order_type) %> • <%= l(order.created_at, format: :short) %></p>
          </div>
          <div class="text-left sm:text-right">
            <p class="text-sm text-stone-500">Total</p>
            <p class="text-lg font-bold text-orange-300"><%= brl(order.total) %></p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="rounded-2xl border border-dashed border-stone-800 bg-stone-900/40 p-6 text-sm text-stone-400">
        Nenhum pedido recente encontrado.
      </div>
    <% end %>
  </div>
</section>

<nav class="fixed inset-x-0 bottom-0 z-50 border-t border-stone-800 bg-[#111313]/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-around px-2 py-3">
    <%= link_to root_path, class: dashboard_nav_link_class(root_path) do %>
      <span aria-hidden="true" class="text-lg">🍽</span>
      <span>Cardapio</span>
    <% end %>
    <%= link_to orders_path, class: dashboard_nav_link_class(orders_path) do %>
      <span aria-hidden="true" class="text-lg">📋</span>
      <span>Pedidos</span>
    <% end %>
    <%= link_to kitchen_path, class: dashboard_nav_link_class(kitchen_path) do %>
      <span aria-hidden="true" class="text-lg">🔥</span>
      <span>Cozinha</span>
    <% end %>
    <%= link_to customers_path, class: dashboard_nav_link_class(customers_path) do %>
      <span aria-hidden="true" class="text-lg">👤</span>
      <span>Clientes</span>
    <% end %>
  </div>
</nav>

<div class="fixed bottom-24 right-4 z-40 sm:right-6">
  <%= link_to new_order_path, class: "flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-300 text-2xl text-stone-950 shadow-lg shadow-amber-400/20 transition hover:rotate-6 hover:bg-amber-200" do %>
    <span aria-hidden="true">⚡</span>
  <% end %>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    var badge = document.getElementById("cart-count");
    var buttons = document.querySelectorAll("[data-add-item]");

    buttons.forEach(function (button) {
      button.addEventListener("click", function () {
        var icon = button.querySelector("[data-add-icon]");
        var current = parseInt(badge.textContent || "0", 10);

        badge.textContent = current + 1;
        badge.classList.add("scale-110");
        icon.textContent = "✓";
        button.classList.add("bg-emerald-500", "text-white");
        button.classList.remove("bg-orange-500", "text-stone-950");

        setTimeout(function () {
          badge.classList.remove("scale-110");
          icon.textContent = "+";
          button.classList.remove("bg-emerald-500", "text-white");
          button.classList.add("bg-orange-500", "text-stone-950");
        }, 1000);
      });
    });
  });
</script>
