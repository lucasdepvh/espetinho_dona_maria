<% content_for :title, "#{@setting.establishment_name} - Dashboard" %>
<% content_for :body_class, "bg-[#121414] text-stone-100 antialiased" %>
<% content_for :main_class, "pb-28" %>
<% content_for :hide_app_header, true %>
<% cart_drawer_open = params[:cart] == "open" %>

<header class="fixed inset-x-0 top-0 z-50 border-b border-stone-800 bg-[#121414]/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <div class="flex items-center gap-4">
      <div class="flex h-11 w-11 items-center justify-center rounded-full bg-stone-900/80 text-xl text-orange-300">
        <span aria-hidden="true">🔥</span>
      </div>
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-stone-500">
          <%= logged_in? ? "Painel da casa" : "Cardapio" %>
        </p>
        <h1 class="text-base font-semibold text-orange-300 sm:text-lg"><%= @setting.establishment_name.upcase %></h1>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <% if logged_in? %>
        <%= link_to logout_path, data: { turbo_method: :delete }, class: "inline-flex items-center rounded-full border border-stone-800 px-4 py-2 text-sm font-medium text-stone-300 transition hover:border-orange-400 hover:text-stone-100" do %>
          Sair
        <% end %>
      <% else %>
        <%= link_to login_path, class: "inline-flex items-center rounded-full border border-stone-800 px-4 py-2 text-sm font-medium text-stone-300 transition hover:border-orange-400 hover:text-stone-100" do %>
          Entrar
        <% end %>
      <% end %>

      <button type="button" data-cart-open class="relative flex h-11 w-11 items-center justify-center rounded-full text-orange-300 transition hover:bg-stone-800" aria-controls="carrinho" aria-expanded="<%= cart_drawer_open %>">
        <span aria-hidden="true" class="text-lg">🛒</span>
        <span id="cart-count" class="absolute right-1 top-1 flex h-5 min-w-5 items-center justify-center rounded-full bg-orange-500 px-1 text-[11px] font-bold text-stone-950"><%= @cart_count %></span>
      </button>
    </div>
  </div>
</header>

<% if logged_in? %>
  <section class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
    <div class="mb-4">
      <h3 class="text-2xl font-semibold text-stone-100">Painel da operacao</h3>
      <p class="text-sm text-stone-400">Somente equipe. Atalhos para fluxo interno sem poluir visao de cliente.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      <% dashboard_operation_links(current_user).each do |link| %>
        <%= link_to link[:path], class: "rounded-2xl border border-stone-800 bg-stone-900/75 p-5 transition hover:border-orange-400" do %>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h4 class="text-lg font-semibold text-stone-100"><%= link[:label] %></h4>
              <p class="mt-2 text-sm text-stone-400"><%= link[:description] %></p>
            </div>
            <span class="text-3xl" aria-hidden="true"><%= link[:emoji] %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<section id="cardapio" class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold text-stone-100">Ofertas de brasa</h3>
      <p class="text-sm text-stone-400">Destaques para acelerar decisao e atendimento.</p>
    </div>
    <%= link_to "Ver categorias", dashboard_path(anchor: "categorias"), class: "text-sm font-semibold text-orange-300 hover:text-orange-200" %>
  </div>

  <% if @featured_products.any? %>
    <div class="flex snap-x gap-4 overflow-x-auto pb-2">
      <% @featured_products.each do |product| %>
        <article class="relative h-56 min-w-[300px] snap-start overflow-hidden rounded-2xl border border-stone-800 bg-stone-900">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(251,146,60,0.30),_transparent_55%),linear-gradient(180deg,_rgba(28,25,23,0.15),_rgba(12,10,9,0.92))]"></div>
          <div class="absolute inset-x-0 bottom-0 p-5">
            <span class="mb-3 inline-flex rounded-md bg-amber-300 px-2 py-1 text-[11px] font-bold tracking-wide text-stone-950"><%= dashboard_promo_label(product) %></span>
            <h4 class="text-xl font-bold text-white"><%= product.name %></h4>
            <p class="mt-1 text-sm text-stone-200"><%= dashboard_product_description(product) %></p>
            <div class="mt-4 flex items-center justify-between gap-4">
              <p class="text-lg font-bold text-orange-300"><%= brl(product.price) %></p>
              <%= button_to dashboard_cart_items_path(product), method: :post, class: "inline-flex items-center rounded-xl bg-orange-500 px-4 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-400" do %>
                Adicionar
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-stone-800 bg-stone-900/40 p-6 text-sm text-stone-400">
      Nenhum destaque disponivel no momento.
    </div>
  <% end %>
</section>

<section id="categorias" class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <h3 class="mb-5 text-2xl font-semibold text-stone-100">Categorias</h3>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    <% @categories.each do |category| %>
      <article class="rounded-2xl border border-stone-800 bg-stone-900/70 p-4 transition hover:border-orange-400">
        <div class="flex aspect-square items-center justify-center rounded-2xl bg-stone-800 text-4xl">
          <span aria-hidden="true"><%= dashboard_category_icon(category.name) %></span>
        </div>
        <div class="mt-3">
          <h4 class="font-semibold text-stone-100"><%= category.name %></h4>
          <p class="mt-1 text-sm text-stone-400"><%= dashboard_category_label(category) %></p>
        </div>
      </article>
    <% end %>
  </div>
</section>

<section class="mx-auto mb-10 max-w-6xl px-4 sm:px-6">
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <h3 class="text-2xl font-semibold text-stone-100">Mais pedidos</h3>
      <p class="text-sm text-stone-400">Itens com giro forte e leitura simples para cliente.</p>
    </div>
    <button type="button" data-cart-open class="text-sm font-semibold text-orange-300 hover:text-orange-200">Ver carrinho</button>
  </div>

  <% if @popular_products.any? %>
    <div class="grid gap-4 lg:grid-cols-2">
      <% @popular_products.each do |product| %>
        <article class="flex gap-4 rounded-2xl border border-stone-800 bg-stone-900/80 p-4 transition hover:border-orange-400">
          <div class="flex h-24 w-24 flex-none items-center justify-center rounded-2xl bg-stone-800 text-4xl">
            <span aria-hidden="true"><%= dashboard_category_icon(product.category.name) %></span>
          </div>
          <div class="flex min-w-0 flex-1 items-center justify-between gap-4">
            <div class="min-w-0">
              <h4 class="truncate text-base font-semibold text-stone-100"><%= product.name %></h4>
              <p class="mt-1 line-clamp-2 text-sm text-stone-400"><%= dashboard_product_description(product) %></p>
              <p class="mt-3 text-lg font-bold text-orange-300"><%= brl(product.price) %></p>
            </div>
            <%= button_to dashboard_cart_items_path(product), method: :post, class: "inline-flex items-center rounded-xl bg-orange-500 px-4 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-400" do %>
              Adicionar
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-dashed border-stone-800 bg-stone-900/40 p-6 text-sm text-stone-400">
      Nenhum produto ativo para exibir.
    </div>
  <% end %>
</section>

<div data-cart-overlay class="fixed inset-0 z-[60] bg-black/45 backdrop-blur-[1px] transition-opacity <%= cart_drawer_open ? "opacity-100" : "pointer-events-none opacity-0" %>">
  <button type="button" data-cart-close class="h-full w-full cursor-default" aria-label="Fechar carrinho"></button>
</div>

<aside id="carrinho" data-cart-drawer class="fixed inset-y-0 right-0 z-[70] flex w-full max-w-[420px] flex-col bg-white text-stone-950 shadow-2xl shadow-black/30 transition-transform duration-200 <%= cart_drawer_open ? "translate-x-0" : "translate-x-full" %>" aria-label="Carrinho">
  <div class="flex items-center justify-between gap-4 px-5 py-6">
    <h3 class="text-xl font-bold text-stone-950">Carrinho de Compras</h3>
    <button type="button" data-cart-close class="flex h-10 w-10 items-center justify-center text-3xl font-light leading-none text-stone-900 transition hover:text-orange-600" aria-label="Fechar carrinho">
      ×
    </button>
  </div>

  <div class="flex-1 overflow-y-auto px-5 pb-5">
    <% if @cart_items.any? %>
      <div class="space-y-5">
        <% @cart_items.each do |item| %>
          <div class="grid grid-cols-[56px_1fr_auto] gap-3">
            <div class="flex h-16 w-14 items-center justify-center rounded-md bg-orange-100 text-2xl">
              <span aria-hidden="true"><%= dashboard_category_icon(item[:product].category.name) %></span>
            </div>

            <div class="min-w-0">
              <p class="line-clamp-2 text-sm font-bold uppercase leading-5 text-stone-900"><%= item[:product].name %></p>
              <p class="mt-1 text-xs text-stone-500"><%= dashboard_product_description(item[:product]) %></p>

              <div class="mt-3 inline-flex h-9 items-center overflow-hidden rounded-md border border-stone-200 bg-white">
                <%= button_to dashboard_cart_item_path(item[:product]), method: :patch, params: { quantity: item[:quantity] - 1 }, class: "flex h-9 w-9 items-center justify-center text-sm text-stone-700 transition hover:bg-stone-100" do %>
                  -
                <% end %>
                <span class="flex h-9 min-w-10 items-center justify-center border-x border-stone-200 px-3 text-sm font-semibold text-stone-900"><%= item[:quantity] %></span>
                <%= button_to dashboard_cart_item_path(item[:product]), method: :patch, params: { quantity: item[:quantity] + 1 }, class: "flex h-9 w-9 items-center justify-center text-sm text-stone-400 transition hover:bg-stone-100 hover:text-stone-900" do %>
                  +
                <% end %>
              </div>
            </div>

            <div class="flex flex-col items-end justify-between gap-4">
              <%= button_to dashboard_cart_item_path(item[:product]), method: :patch, params: { quantity: 0 }, class: "flex h-8 w-8 items-center justify-center text-xl text-stone-500 transition hover:text-red-700", aria: { label: "Remover #{item[:product].name}" } do %>
                🗑
              <% end %>
              <p class="whitespace-nowrap text-sm font-bold text-stone-950"><%= brl(item[:total]) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-8 rounded-lg border border-dashed border-stone-200 bg-stone-50 p-6 text-center">
        <p class="text-lg font-semibold text-stone-950">Carrinho vazio</p>
        <p class="mt-2 text-sm text-stone-500">Adicione itens do cardapio para montar pedido com rapidez.</p>
        <div class="mt-4">
          <button type="button" data-cart-close class="inline-flex items-center rounded-full border border-stone-300 px-5 py-3 text-sm font-semibold text-stone-900 transition hover:border-orange-500">Continuar comprando</button>
        </div>
      </div>
    <% end %>
  </div>

  <div class="border-t border-stone-200 bg-white px-5 pb-6 pt-5">
    <div class="mb-5 space-y-1 text-sm">
      <div class="flex items-center justify-between gap-4 text-stone-600">
        <span>Subtotal</span>
        <span><%= brl(@cart_total) %></span>
      </div>
      <div class="flex items-center justify-between gap-4 text-stone-600">
        <span>Desconto</span>
        <span>-R$ 0,00</span>
      </div>
      <div class="flex items-center justify-between gap-4 text-xs font-bold text-stone-950">
        <span>Total</span>
        <span><%= brl(@cart_total) %></span>
      </div>
    </div>

    <% if @cart_items.any? %>
      <% if logged_in? %>
        <%= link_to "Lancar pedido", new_order_path, class: "flex w-full items-center justify-center rounded-full bg-stone-950 px-4 py-4 text-base font-bold text-white transition hover:bg-stone-800" %>
      <% else %>
        <%= button_to "Solicitar no WhatsApp", dashboard_cart_whatsapp_path, method: :post, class: "flex w-full items-center justify-center rounded-full bg-stone-950 px-4 py-4 text-base font-bold text-white transition hover:bg-stone-800" %>
      <% end %>
      <button type="button" data-cart-close class="mt-3 flex w-full items-center justify-center rounded-full border border-stone-300 px-4 py-3 text-sm font-semibold text-stone-800 transition hover:border-stone-500">Continuar comprando</button>
      <p class="mt-4 text-center text-[10px] font-semibold uppercase tracking-[0.18em] text-stone-400">O pedido sera enviado pelo WhatsApp</p>
    <% end %>
  </div>
</aside>

<% if logged_in? %>
  <section class="mx-auto mb-8 max-w-6xl px-4 sm:px-6">
    <div class="mb-4 flex items-end justify-between gap-4">
      <div>
        <h3 class="text-2xl font-semibold text-stone-100">Pedidos em andamento</h3>
        <p class="text-sm text-stone-400">Acompanhe o que precisa de atencao imediata.</p>
      </div>
      <%= link_to "Abrir pedidos", orders_path, class: "text-sm font-semibold text-orange-300 hover:text-orange-200" %>
    </div>

    <div class="grid gap-3">
      <% if @latest_orders.any? %>
        <% @latest_orders.each do |order| %>
          <%= link_to order_path(order), class: "flex flex-col gap-3 rounded-2xl border border-stone-800 bg-stone-900/70 p-4 transition hover:border-orange-400 sm:flex-row sm:items-center sm:justify-between" do %>
            <div>
              <div class="flex items-center gap-3">
                <span class="rounded-full bg-stone-800 px-3 py-1 text-xs font-semibold text-stone-300">Pedido #<%= order.id %></span>
                <span class="rounded-full px-3 py-1 text-xs font-semibold <%= dashboard_status_badge_class(order.status) %>"><%= order_status_label(order.status) %></span>
              </div>
              <p class="mt-3 text-base font-semibold text-stone-100"><%= order.customer.name %></p>
              <p class="text-sm text-stone-400"><%= order_type_label(order.order_type) %> • <%= l(order.created_at, format: :short) %></p>
            </div>
            <div class="text-left sm:text-right">
              <p class="text-sm text-stone-500">Total</p>
              <p class="text-lg font-bold text-orange-300"><%= brl(order.total) %></p>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <div class="rounded-2xl border border-dashed border-stone-800 bg-stone-900/40 p-6 text-sm text-stone-400">
          Nenhum pedido recente encontrado.
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<nav class="fixed inset-x-0 bottom-0 z-50 border-t border-stone-800 bg-[#111313]/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-around px-2 py-3">
    <%= link_to dashboard_path(anchor: "cardapio"), class: dashboard_nav_link_class(active: true) do %>
      <span aria-hidden="true" class="text-lg">🍽</span>
      <span>Cardapio</span>
    <% end %>

    <% if logged_in? %>
      <%= link_to orders_path, class: dashboard_nav_link_class(orders_path) do %>
        <span aria-hidden="true" class="text-lg">📋</span>
        <span>Pedidos</span>
      <% end %>
      <%= link_to kitchen_path, class: dashboard_nav_link_class(kitchen_path) do %>
        <span aria-hidden="true" class="text-lg">🔥</span>
        <span>Cozinha</span>
      <% end %>
      <%= link_to customers_path, class: dashboard_nav_link_class(customers_path) do %>
        <span aria-hidden="true" class="text-lg">👤</span>
        <span>Clientes</span>
      <% end %>
    <% else %>
      <%= link_to dashboard_path(anchor: "categorias"), class: dashboard_nav_link_class do %>
        <span aria-hidden="true" class="text-lg">🏷</span>
        <span>Categorias</span>
      <% end %>
      <button type="button" data-cart-open class="<%= dashboard_nav_link_class %>">
        <span aria-hidden="true" class="text-lg">🛒</span>
        <span>Carrinho</span>
      </button>
      <%= link_to login_path, class: dashboard_nav_link_class(login_path) do %>
        <span aria-hidden="true" class="text-lg">🔐</span>
        <span>Entrar</span>
      <% end %>
    <% end %>
  </div>
</nav>

<% if logged_in? %>
  <div class="fixed bottom-24 right-4 z-40 sm:right-6">
    <%= link_to new_order_path, class: "flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-300 text-2xl text-stone-950 shadow-lg shadow-amber-400/20 transition hover:rotate-6 hover:bg-amber-200" do %>
      <span aria-hidden="true">⚡</span>
    <% end %>
  </div>
<% end %>

<script>
  document.addEventListener("turbo:load", function () {
    var drawer = document.querySelector("[data-cart-drawer]");
    var overlay = document.querySelector("[data-cart-overlay]");
    var openButtons = document.querySelectorAll("[data-cart-open]");
    var closeButtons = document.querySelectorAll("[data-cart-close]");

    if (!drawer || !overlay) return;

    function setExpanded(value) {
      openButtons.forEach(function (button) {
        button.setAttribute("aria-expanded", value ? "true" : "false");
      });
    }

    function openCart() {
      drawer.classList.remove("translate-x-full");
      drawer.classList.add("translate-x-0");
      overlay.classList.remove("pointer-events-none", "opacity-0");
      overlay.classList.add("opacity-100");
      document.body.classList.add("overflow-hidden");
      setExpanded(true);
    }

    function closeCart() {
      drawer.classList.add("translate-x-full");
      drawer.classList.remove("translate-x-0");
      overlay.classList.add("pointer-events-none", "opacity-0");
      overlay.classList.remove("opacity-100");
      document.body.classList.remove("overflow-hidden");
      setExpanded(false);
    }

    openButtons.forEach(function (button) {
      button.addEventListener("click", openCart);
    });

    closeButtons.forEach(function (button) {
      button.addEventListener("click", closeCart);
    });

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") closeCart();
    });

    if (drawer.classList.contains("translate-x-0")) {
      document.body.classList.add("overflow-hidden");
      setExpanded(true);
    }
  });
</script>
