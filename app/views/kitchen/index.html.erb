<div class="space-y-5">
  <h1 class="text-3xl font-bold">Cozinha</h1>
  <div class="grid gap-4 lg:grid-cols-2">
    <% @orders.each do |order| %>
      <article class="rounded-lg border bg-white p-5">
        <div class="flex items-start justify-between">
          <div>
            <h2 class="text-xl font-bold">Pedido #<%= order.id %></h2>
            <p class="text-sm text-stone-600"><%= order_type_label(order.order_type) %> - <%= order.table? ? "Mesa #{order.table_number}" : order.customer.name %></p>
          </div>
          <span class="rounded-full px-3 py-1 text-sm <%= status_badge_class(order.status) %>"><%= order_status_label(order.status) %></span>
        </div>
        <div class="mt-4 divide-y">
          <% order.order_items.each do |item| %>
            <div class="py-3">
              <p class="font-medium"><%= item.quantity %>x <%= item.product.name %></p>
              <% if item.notes.present? %><p class="text-sm text-stone-500">Obs: <%= item.notes %></p><% end %>
            </div>
          <% end %>
        </div>
        <% if order.notes.present? %><p class="mt-3 rounded-md bg-stone-100 p-3 text-sm"><%= order.notes %></p><% end %>
        <div class="mt-4 flex gap-2">
          <%= button_to "Em preparo", update_status_order_path(order, status: :preparing), method: :patch, class: "rounded-md bg-amber-700 px-4 py-2 text-white" %>
          <%= button_to "Pronto", update_status_order_path(order, status: :ready), method: :patch, class: "rounded-md bg-emerald-700 px-4 py-2 text-white" %>
        </div>
      </article>
    <% end %>
  </div>
</div>
