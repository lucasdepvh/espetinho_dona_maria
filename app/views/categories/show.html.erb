<div class="rounded-lg border bg-white p-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-3xl font-bold"><%= @category.name %></h1>
      <p class="mt-2 text-stone-600"><%= @category.description.presence || "Sem descricao." %></p>
      <p class="mt-2 text-sm"><%= @category.active? ? "Ativa" : "Inativa" %></p>
    </div>
    <%= link_to "Editar", edit_category_path(@category), class: "rounded-md border px-4 py-2" %>
  </div>
</div>
